{
  "hike-backpack": {
    "label": "Hike, camp, or backpack",
    "pose": "standing",
    "baseSlots": [
      "boots",
      "pack",
      "pants",
      "baselayer",
      "midlayer",
      "shell",
      "headwear",
      "hydration"
    ],
    "modifiers": {
      "cold":     { "add": ["insulation", "gloves"] },
      "winter":   { "add": ["insulation", "gloves"] },
      "wet":      { "promote": ["shell"], "add": [] },
      "hot":      { "add": ["sunglasses"], "remove": ["midlayer", "insulation"] },
      "summer":   { "add": ["sunglasses"], "remove": ["midlayer", "insulation"] },
      "altitude": { "add": ["insulation", "sunglasses"] },
      "multiday": { "add": ["tent", "sleeping-bag", "sleeping-pad", "stove", "headlamp"] }
    }
  },
  "climb": {
